# ---------------------- 任务2：5日、20日移动平均线MA ----------------------
print("\n----- 任务2：移动平均线 MA5 / MA20 -----")
price_series = rng.uniform(50, 150, size=100)

def moving_avg_cumsum(x, window):
    cumsum = np.cumsum(np.insert(x, 0, 0))
    ma = (cumsum[window:] - cumsum[:-window]) / window
    return ma

ma5 = moving_avg_cumsum(price_series, 5)
ma20 = moving_avg_cumsum(price_series, 20)
print(f"原始价格长度: {len(price_series)}")
print(f"MA5长度: {len(ma5)}, MA20长度: {len(ma20)}")
print("MA5前10个数值：", np.round(ma5[:10], 2))


# ====================== 拓展：蒙特卡洛股票模拟 ======================
print("\n==================== 拓展：几何布朗运动蒙特卡洛模拟 ====================")
def monte_carlo_stock(S0, mu, sigma, years=1, n_sim=2000):
    dt = 1 / 252
    n_days = int(252 * years)
    Z = rng.standard_normal((n_days, n_sim))
    drift = (mu - 0.5 * sigma ** 2) * dt
    shock = sigma * np.sqrt(dt) * Z
    log_ret = drift + shock
    cum_log = np.cumsum(log_ret, axis=0)
    paths = S0 * np.exp(cum_log)
    paths = np.vstack([np.full(n_sim, S0), paths])
    return paths

sim_paths = monte_carlo_stock(S0=100, mu=0.08, sigma=0.2, years=1, n_sim=2000)
print("模拟路径形状(天数+1,模拟次数)：", sim_paths.shape)
print("全部路径期末价格均值：", round(sim_paths[-1].mean(), 2))

# ---------------------- 任务1：对数收益率计算 ----------------------
print("\n----- 任务1：股价对数收益率 -----")
prices = np.array([100, 102, 105, 103, 107])
log_prices = np.log(prices)
log_returns = np.diff(log_prices)
